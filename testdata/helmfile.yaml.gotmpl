repositories:
  - name: bitnami
    url: https://charts.bitnami.com/bitnami
  - name: ingress-nginx
    url: https://kubernetes.github.io/ingress-nginx

releases:
  - name: nginx-ingress
    namespace: {{ .Values.ingressNamespace | default "ingress" }}
    chart: ingress-nginx/ingress-nginx
    version: 4.0.1
    values:
      - replicaCount: {{ .Values.ingressReplicas | default 2 }}

  - name: postgresql
    namespace: {{ .Values.dbNamespace | default "database" }}
    chart: bitnami/postgresql
    version: 11.6.0
    set:
      - name: auth.postgresPassword
        value: {{ requiredEnv "DB_PASSWORD" }}

  - name: redis
    namespace: cache
    chart: bitnami/redis
    version: {{ .Values.redisVersion | default "16.13.0" }}
