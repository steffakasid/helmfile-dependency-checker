{
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "!.github/**"
      ],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    },
    {
      "description": "Do not update helmfile fixtures under testdata",
      "matchFileNames": [
        "testdata/**/helmfile*.yaml",
        "testdata/**/helmfile*.yml",
        "testdata/**/helmfile*.gotmpl"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "golang-version"
      ],
      "rangeStrategy": "bump"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.*go$/"
      ],
      "matchStrings": [
        "//go:generate go run (?<depName>.+?)@(?<currentValue>.*?)\\n$"
      ],
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.github\\/workflows\\/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?<depName>go)-version: (?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version"
    }
  ]
}